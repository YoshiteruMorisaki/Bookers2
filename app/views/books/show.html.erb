<div class="container mt-4">
  <div class="row">
    <div class="col-md-3">
      <%= render "shared/sidebar", user: @user, book: @book_new, context: "user_show" %>
    </div>

    <div class="col-md-8 offset-md-1">
      <h2 class="mb-3">Book detail</h2>

      <div class="table-responsive">
        <table class="table align-middle">
          <tbody>
            <tr>
              <td style="width: 140px;">
                <div class="d-flex align-items-center justify-content-center">
                  <%= profile_image_tag(@book.user, size: 100) %>
                </div>
                <div class="mt-2">
                  <%= link_to @book.user.name, user_path(@book.user), class: "text-decoration-none fw-bold" %>
                </div>
              </td>

              <td style="width: 35%;">
                <%= @book.title %>
              </td>

              <td>
                <%= @book.body %>
              </td>

              <td class="text-nowrap" style="width: 120px;">
                <%= render "favorites/button", book: @book %>
              </td>

              <td class="text-nowrap" style="width: 180px;">
                コメント数: <%= @book.book_comments.size %>
              </td>

              <% if @book.user == current_user %>
                <td class="text-end text-nowrap" style="width: 180px;">
                  <%= link_to "Edit", edit_book_path(@book), class: "btn btn-success btn-sm" %>
                  <%= link_to "Destroy", book_path(@book),
                              data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
                              class: "btn btn-danger btn-sm ms-2" %>
                </td>
              <% end %>
            </tr>
          </tbody>
        </table>
      </div>

      <hr class="my-4">

      <h4 class="mb-3">Comments (<%= @book.book_comments.size %>)</h4>

      <%# コメント一覧 %>
      <% if @book_comments.present? %>
        <div class="list-group mb-4">
          <% @book_comments.each do |c| %>
            <div class="list-group-item">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex gap-2">
                  <%= profile_image_tag(c.user, size: 40) %>
                  <div>
                    <div class="fw-bold">
                      <%= link_to c.user.name, user_path(c.user), class: "text-decoration-none" %>
                    </div>
                    <div class="text-muted small">
                      <%= c.created_at.strftime("%Y/%m/%d %H:%M") %>
                    </div>
                  </div>
                </div>

                <% if c.user == current_user %>
                  <%= link_to "Delete",
                              book_book_comment_path(@book, c),
                              data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
                              class: "btn btn-outline-danger btn-sm" %>
                <% end %>
              </div>

              <div class="mt-2">
                <%= simple_format(h(c.comment)) %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted">まだコメントがありません。</p>
      <% end %>

      <%# コメント作成フォーム %>
      <% if @book_comment&.errors&.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @book_comment.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: [@book, @book_comment], local: true do |f| %>
        <div class="mb-3">
          <%= f.text_area :comment, class: "form-control", rows: 4, placeholder: "コメントを書いて送信…" %>
        </div>
        <%= f.submit "送信", class: "btn btn-secondary" %>
      <% end %>

    </div>
  </div>
</div>
